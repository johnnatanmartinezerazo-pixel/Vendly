{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
    "version": "0.2",
    "ignorePaths": [
        "node_modules",
        "dist",
        "public",
        "src-tauri/build",
        "src-tauri/target",
        "src-tauri/gen",
        "src-tauri/capabilities",
        "src-tauri/icons"
    ],
    "words": [
        "vendly",
        "Tauri",
        "Vite",
        "TailwindCSS",
        "Prettier",
        "ESLint",
        "Vitest",
        "Jest",
        "cspell",
        "jsx-a11y",
        "typescript-eslint",
        "tokio",
        "serde",
        "serde_json",
        "tauri-plugin-opener",
        "tauri-plugin-dialogs",
        "tauri-plugin-shell",
        "tauri-plugin-updater",
        "tauri-plugin-clipboard",
        "tauri-plugin-local-storage",
        "tauri-plugin-notification",
        "tauri-plugin-global-shortcut",
        "tauri-plugin-os",
        "tauri-plugin-process",
        "tauri-plugin-window",
        "tauri-plugin-logger",
        "tauri-plugin-dialogs",
        "tauri-plugin-shell",
        "tauri-plugin-updater",
        "tauri-plugin-clipboard",
        "tauri-plugin-local-storage",
        "tauri-plugin-notification",
        "tauri-plugin-global-shortcut"
    ],
    "ignoreWords": [
        "vendly",
        "vite",
        "tauri",
        "react",
        "react-dom",
        "tailwindcss",
        "eslint",
        "jest",
        "prettier",
        "cspell",
        "jsx-a11y"
    ],
    "language": "en,es",
  "dictionaries": [
    "en",
    "es"
  ],
  "dictionaryDefinitions": [
    {
      "name": "es",
      "path": "@cspell/dict-es-es/spanish.txt.gz",
      "description": "Diccionario español"
    }
  ],
    "enableFiletypes": [
        "javascript",
        "typescript",
        "javascriptreact",
        "typescriptreact",
        "json",
        "jsonc",
        "markdown",
        "html",
        "css",
        "scss",
        "less",
        "yaml",
        "yml",
        "rust",
        "scheme"
    ],
    "allowCompoundWords": true,
    "gitignoreRoot": ".",
    "globRoot": ".",
    "ignoreRandomStrings": true
}
